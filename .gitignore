# ====== Python 环境 ======
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ====== 虚拟环境 ======
.venv/
venv/
env/
ENV/

# ====== IDE / 编辑器 ======
.idea/
.vscode/
*.iml
*.swp
*.swo

# ====== 数据与结果文件（体积大，不适合存 Git） ======
*.npz
*.csv
*.xls
*.xlsx

# ====== 图片与文档输出（可按需保留） ======
